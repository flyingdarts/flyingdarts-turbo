{
  "$id": "fd-v2.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FlyingDarts Monorepo Workspace Schema",
  "type": "object",
  "properties": {
    "apps": {
      "type": "object",
      "properties": {
        "backend": {
          "type": "object",
          "properties": {
            "dotnet": { "$ref": "types/apps.dotnet.schema.json" }
          },
          "additionalProperties": false
        },
        "frontend": {
          "type": "object",
          "properties": {
            "flutter": { "$ref": "types/apps.flutter.schema.json" }
          },
          "additionalProperties": false
        },
        "tools": {
          "type": "object",
          "properties": {
            "dotnet": { "$ref": "types/apps.dotnet.schema.json" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "packages": {
      "type": "object",
      "properties": {
        "backend": {
          "type": "object",
          "properties": {
            "dotnet": { "$ref": "types/packages.dotnet.schema.json" }
          },
          "additionalProperties": false
        },
        "frontend": {
          "type": "object",
          "properties": {
            "flutter": { "$ref": "types/packages.flutter.schema.json" }
          },
          "additionalProperties": false
        },
        "tools": {
          "type": "object",
          "properties": {
            "dotnet": { "$ref": "types/packages.dotnet.schema.json" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["apps", "packages"],
  "additionalProperties": false
}
