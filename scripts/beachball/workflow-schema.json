{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://flyingdarts.com/schemas/workflow-schema.json",
  "title": "Workflow State Machine Schema",
  "description": "Schema for validating workflow state machine definitions",
  "type": "object",
  "required": ["workflow"],
  "properties": {
    "workflow": {
      "type": "object",
      "required": ["name", "description", "version", "events", "states"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9]*$",
          "description": "The name of the workflow (must be a valid identifier)"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "A description of what the workflow does"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version of the workflow (e.g., 1.0.0)"
        },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9]*$",
                "description": "Event name (must be a valid identifier)"
              },
              "description": {
                "type": "string",
                "minLength": 1,
                "description": "Description of what the event represents"
              }
            },
            "additionalProperties": false
          },
          "uniqueItems": true
        },
        "states": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["id", "name", "description"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$",
                "description": "Unique state identifier (kebab-case)"
              },
              "name": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9]*$",
                "description": "State name (must be a valid identifier)"
              },
              "description": {
                "type": "string",
                "minLength": 1,
                "description": "Description of what the state does"
              },
              "isInitial": {
                "type": "boolean",
                "description": "Whether this is the initial state"
              },
              "isFinal": {
                "type": "boolean",
                "description": "Whether this is a final state"
              },
              "actions": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": ["type", "level", "message"],
                      "properties": {
                        "type": {
                          "const": "log",
                          "description": "Log action type"
                        },
                        "level": {
                          "enum": ["info", "success", "warning", "error"],
                          "description": "Log level"
                        },
                        "message": {
                          "type": "string",
                          "minLength": 1,
                          "description": "Log message"
                        }
                      },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": ["type"],
                      "properties": {
                        "type": {
                          "type": "string",
                          "pattern": "^[a-z][a-z0-9-]*$",
                          "description": "Custom action type (kebab-case)"
                        },
                        "question": {
                          "type": "string",
                          "description": "Question for user prompt actions"
                        }
                      },
                      "additionalProperties": false
                    }
                  ]
                }
              },
              "transitions": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["event", "target"],
                  "properties": {
                    "event": {
                      "type": "string",
                      "description": "Event that triggers this transition"
                    },
                    "target": {
                      "type": "string",
                      "pattern": "^[a-z][a-z0-9-]*$",
                      "description": "Target state ID (kebab-case)"
                    },
                    "condition": {
                      "type": "string",
                      "description": "Optional condition for the transition"
                    },
                    "description": {
                      "type": "string",
                      "description": "Description of the transition"
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "uniqueItems": true
        },
        "codeGeneration": {
          "type": "object",
          "properties": {
            "language": {
              "type": "string",
              "enum": ["csharp", "typescript", "python", "java"],
              "description": "Target programming language"
            },
            "namespace": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9.]*$",
              "description": "Namespace for generated code"
            },
            "baseClass": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9]*$",
              "description": "Base class name"
            },
            "generateInterfaces": {
              "type": "boolean",
              "description": "Whether to generate interfaces"
            },
            "generateTests": {
              "type": "boolean",
              "description": "Whether to generate tests"
            },
            "customActions": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "description", "returnType"],
                "properties": {
                  "name": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$",
                    "description": "Action name (kebab-case)"
                  },
                  "description": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Action description"
                  },
                  "parameters": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["name", "type"],
                      "properties": {
                        "name": {
                          "type": "string",
                          "pattern": "^[a-z][a-z0-9]*$",
                          "description": "Parameter name (camelCase)"
                        },
                        "type": {
                          "type": "string",
                          "enum": ["string", "int", "bool", "float"],
                          "description": "Parameter type"
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "returnType": {
                    "type": "string",
                    "enum": ["string", "int", "bool", "float", "void"],
                    "description": "Return type of the action"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "validation": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["rule", "description"],
            "properties": {
              "rule": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$",
                "description": "Validation rule name (kebab-case)"
              },
              "description": {
                "type": "string",
                "minLength": 1,
                "description": "Description of the validation rule"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "type": "object",
        "properties": {
          "workflow": {
            "type": "object",
            "properties": {
              "states": {
                "type": "array"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "workflow": {
            "properties": {
              "states": {
                "items": {
                  "allOf": [
                    {
                      "if": {
                        "properties": {
                          "isInitial": { "const": true }
                        }
                      },
                      "then": {
                        "properties": {
                          "transitions": {
                            "type": "array",
                            "minItems": 1
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  ]
}
