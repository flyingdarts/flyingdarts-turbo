{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "restore": {
      "outputs": ["**/obj/**", "**/bin/**", "**/node_modules/**"]
    },
    "^build": {
      "cache": true
    },
    "build": {
      "outputs": [
        "bin/Debug/*/**",
        "obj/Debug/*/**",
        "build/**",
        "dist/**",
        "!package.json"
      ]
    },
    "build:flutter": {
      "outputs": ["build/**", "!package.json"]
    },
    "build:prod": {
      "dependsOn": ["build"],
      "outputs": [
        "bin/Release/*/**",
        "obj/Release/*/**",
        "build/**",
        "dist/**",
        "!package.json"
      ],
      "cache": false
    }
  }
}
