{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "cache": true
    },
    "build:dev": {
      "dependsOn": ["build"],
      "outputs": ["bin/Debug/*/**", "obj/Debug/*/**"],
      "cache": true
    },
    "build:prod": {
      "dependsOn": ["build"],
      "outputs": ["bin/Release/*/**", "obj/Release/*/**"],
      "cache": false
    },
    "deploy:dev": {
      "dependsOn": ["build:dev"],
      "cache": false
    },
    "deploy:prod": {
      "dependsOn": ["build:prod"],
      "cache": false
    },
    "serve": {
      "persistent": true
    },
    "dockerize": {
      "dependsOn": ["build:prod"],
      "cache": false
    }
  }
}
