{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "restore": {
      "outputs": [
        "**/obj/**",
        "**/bin/**",
        "**/node_modules/**"
      ]
    },
    // Cache all build tasks
    "^build": {
      "cache": true
    },
    // Generic build step for all packages
    "build": {
      "outputs": [
        "bin/Debug/*/**",
        "obj/Debug/*/**", // .NET outputs
        "build/**", // Flutter outputs
        "!package.json"
      ]
    },
    // Production build step
    "build:prod": {
      "dependsOn": ["build"],
      "outputs": [
        "bin/Release/*/**",
        "obj/Release/*/**", // .NET outputs
        "build/**", // Flutter outputs
        "!package.json"
      ],
      "cache": false
    }
  }
}
