{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    // Cache all build tasks
    "^build": {
      "cache": true
    },
    // Generic build step for all packages
    "build": {
      "outputs": [
        "bin/Debug/*/**",
        "obj/Debug/*/**", // .NET outputs
        "build/**", // Flutter outputs
        "!package.json"
      ]
    },
    // Production build step
    "build:prod": {
      "dependsOn": ["build"],
      "outputs": [
        "bin/Release/*/**",
        "obj/Release/*/**", // .NET outputs
        "build/**", // Flutter outputs
        "!package.json"
      ],
      "cache": false
    },
    // Development deploy (mainly for backend/dotnet)
    "deploy:dev": {
      "dependsOn": ["build"],
      "cache": false
    },
    // Production deploy (mainly for backend/dotnet)
    "deploy:prod": {
      "dependsOn": ["build:prod"],
      "cache": false
    },
    // Serve (mainly for frontend)
    "serve": {
      "persistent": true
    },
    // Dockerize (mainly for frontend Flutter)
    "dockerize": {
      "dependsOn": ["build:prod"],
      "cache": false
    }
  }
}
