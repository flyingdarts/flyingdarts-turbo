{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "outputs": [
        "bin/Debug/net6.0/**",
        "obj/Debug/net6.0/**"
      ],
      "cache": false
    },
    "build:prod": {
      "outputs": [
        "bin/Release/net6.0/**",
        "obj/Release/net6.0/**"
      ],
      "cache": false
    },
    "deploy": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "deploy:development": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "deploy:production": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "serve": {
      "outputMode": "full",
      "persistent": true
    },
    "dockerize": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    }
  }
}