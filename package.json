{
	"name": "flyingdarts",
	"workspaces": [
		"packages/**",
		"apps/backend/**",
		"apps/frontend/**",
		"apps/tools/**"
	],
	"dependencies": {
		"turbo": "latest"
	},
	"packageManager": "npm@9.5.0",
	"scripts": {
		"generate-files": "turbo run generate --log-order=grouped --filter=./apps/frontend/flutter/**",
		"build-packages-development": "turbo run build:development --log-order=stream --filter=./packages/** --concurrency=1",
		"build-packages-production": "turbo run build:production --log-order=stream --filter=./packages/** --concurrency=1",
		"build-backend-development": "turbo run build:development --log-order=grouped --filter=./apps/backend/**",
		"build-backend-production": "turbo run build:production --log-order=grouped --filter=./apps/backend/**",
		"build-frontend-development": "turbo run build:development --log-order=grouped --filter=./apps/frontend/**",
		"build-frontend-production": "turbo run build:production --log-order=grouped --filter=./apps/frontend/**",
		"deploy-signalling-development": "turbo run deploy:development --log-order=stream --filter=./apps/backend/signalling/** --concurrency=1",
		"deploy-signalling-production": "turbo run deploy:production --log-order=stream --filter=./apps/backend/signalling/** --concurrency=1",
		"deploy-games-development": "turbo run deploy:development --log-order=stream --filter=./apps/backend/games/** --concurrency=1",
		"deploy-games-production": "turbo run deploy:production --log-order=stream --filter=./apps/backend/games/** --concurrency=1",
		"deploy-user-development": "turbo run deploy:development --log-order=stream --filter=./apps/backend/user/** --concurrency=1",
		"deploy-user-production": "turbo run deploy:production --log-order=stream --filter=./apps/backend/user/** --concurrency=1",
		"deploy-tournaments-development": "turbo run deploy:development --log-order=stream --filter=./apps/backend/tournaments/** --concurrency=1",
		"deploy-tournaments-production": "turbo run deploy:production --log-order=stream --filter=./apps/backend/tournaments/** --concurrency=1",
		"deploy-backend-development": "turbo run deploy:development --log-order=stream --filter=./apps/backend/** --concurrency=1",
		"deploy-backend-production": "turbo run deploy:production --log-order=stream --filter=./apps/backend/** --concurrency=1",
		"deploy-infra-development": "turbo run deploy:development --log-order=stream --filter=./apps/tools/infrastructure",
		"deploy-infra-production": "turbo run deploy:production --log-order=stream --filter=./apps/tools/infrastructure",
		"serve-angular": "turbo run serve --log-order=stream --filter=./apps/frontend/angular",
		"serve-flutter": "turbo run serve --log-order=stream --filter=./apps/frontend/flutter",
		"dockerize": "turbo run dockerize --log-order=grouped --filter=flyingdarts.frontend.flutter..."
	},
	"repository": {
		"url": "https://github.com/flyingdarts/flyingdarts-turbo",
		"type": "git"
	}
}
