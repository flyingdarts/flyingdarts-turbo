pipeline {
    agent any
    
    environment {
        DOTNET_ROOT = tool name: 'dotnet', type: 'Tool'
    }
    
    stages {
        stage('Install .NET SDK') {
            steps {
                sh 'wget -q https://dot.net/v1/dotnet-install.sh'
                sh 'chmod +x dotnet-install.sh'
                sh './dotnet-install.sh -c Current'
            }
        }
    
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Restore') {
            steps {
                script {
                    // Restore NuGet packages
                    sh "${env.DOTNET_ROOT}/dotnet restore"
                }
            }
        }

        stage('Build') {
            steps {
                script {
                    // Build the .csproj projects
                    sh "${env.DOTNET_ROOT}/dotnet build -c Release -o packages"
                }
            }
        }

    }

    post {
        success {
            archiveArtifacts artifacts: 'packages/**/*', allowEmptyArchive: true
        }
    }
}
